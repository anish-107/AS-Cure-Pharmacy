# .gitignore
# @author Dibyasmita
# @date 18-1-2026
# @description This file contains the name of files that should not be pushed to github.
# @returns Nothing


# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Modules
node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.env

# Files
**/*.pdf
**/*.docx